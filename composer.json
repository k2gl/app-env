{
  "name": "k2gl/app-env",
  "description": "Run code conditionally on the current application environment (prod, dev, test).",
  "homepage": "https://github.com/k2gl/app-env",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "php",
    "appenv",
    "app env",
    "application environment"
  ],
  "authors": [
    {
      "name": "Nick Harin",
      "email": "l0gic@ya.ru"
    }
  ],
  "support": {
    "issues": "https://github.com/k2gl/app-env/issues",
    "source": "https://github.com/k2gl/app-env"
  },
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5|^11.0|^12.0",
    "phpstan/phpstan": "^2.1",
    "laravel/pint": "~1.20.0",
    "k2gl/phpunit-fluent-assertions": "^12"
  },
  "autoload": {
    "psr-4": {
      "K2gl\\Component\\AppEnv\\": ""
    },
    "exclude-from-classmap": [
      "/Tests/"
    ]
  },
  "minimum-stability": "stable",
  "scripts": {
    "test": "phpunit",
    "phpstan": "phpstan analyse",
    "cs": "pint --test",
    "cs-fix": "pint",
    "check": [
      "@test",
      "@phpstan",
      "@cs"
    ]
  }
}
