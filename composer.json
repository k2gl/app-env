{
  "name": "k2gl/app-env",
  "description": "PHP application environment service",
  "homepage": "https://github.com/k2gl/app-env",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "php",
    "appenv",
    "app env",
    "application environment"
  ],
  "authors": [
    {
      "name": "Nickolay Harin",
      "email": "l0gic@ya.ru"
    }
  ],
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5|^11.0|^12.0",
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.64",
    "k2gl/phpunit-fluent-assertions": "^12"
  },
  "autoload": {
    "psr-4": {
      "K2gl\\Component\\AppEnv\\": ""
    },
    "exclude-from-classmap": [
      "/Tests/"
    ]
  },
  "minimum-stability": "stable",
  "scripts": {
    "test": "phpunit",
    "phpstan": "phpstan analyse",
    "cs": "php-cs-fixer fix --dry-run --diff",
    "cs-fix": "php-cs-fixer fix"
  }
}
